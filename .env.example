# Copy values into .env.local or set them in your shell. Do not put real secrets in this file.

# Lark / Feishu bot credentials
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx

# LLM provider key used by workflowRoles.assistant.
# The variable name must match profiles.<assistant-profile>.apiKeyEnv.
ASSISTANT_API_KEY=replace_me

# Optional keys for additional profiles.
# Add only the env names referenced by profiles.<profile>.apiKeyEnv.
ROLE_AGENT_API_KEY=replace_me
