# Copy values into .env.local or set them in your shell. Do not put real secrets in this file.

# Lark / Feishu bot credentials
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx

# OpenAI-compatible chat provider used by workflowRoles.assistant.
# The variable name must match profiles.<assistant-profile>.apiKeyEnv.
ASSISTANT_API_KEY=sk_xxx

# Optional examples for other local-only provider keys.
OPENAI_API_KEY=sk_xxx
DEEPSEEK_API_KEY=sk_xxx
GEMINI_API_KEY=xxx
ANTHROPIC_API_KEY=sk-ant-xxx
